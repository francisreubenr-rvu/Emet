# Backend core
DATABASE_URL=postgresql+psycopg://emet:emet_password@localhost:5432/emet
REDIS_URL=redis://localhost:6379/0
SECRET_KEY=change-this-jwt-secret
COOKIE_SECURE=false
CORS_ORIGINS=http://localhost:3000

# Scan safety
ALLOW_INTERNAL_SCANNING=false

# Scanner and pipeline
DATASET_PATH=./datasets
FAISS_INDEX_PATH=./embeddings/faiss_index
MOCK_MODE=false

# Optional scanner credentials
NESSUS_URL=https://localhost:8834
NESSUS_ACCESS_KEY=
NESSUS_SECRET_KEY=
OPENVAS_HOST=localhost
OPENVAS_PORT=9390
OPENVAS_USERNAME=
OPENVAS_PASSWORD=

# AI/model providers (all optional for Phase 1 fallback)
GEMINI_API_KEY=
OPENAI_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# Enrichment keys (optional)
NVD_API_KEY=
SHODAN_API_KEY=
VIRUSTOTAL_API_KEY=
HIBP_API_KEY=
GITHUB_TOKEN=

# Ingestion scheduler and safety
INGEST_SCHEDULER_ENABLED=true
INGEST_INTERVAL_MINUTES=180
INGEST_NVD_ENABLED=true
INGEST_OSV_ENABLED=true
INGEST_ALLOWED_ROOT=/app/datasets

# Scanner ingest/report safety
SCAN_REPORT_ALLOWED_ROOT=/app/artifacts
SCAN_REPO_ALLOWED_ROOT=/app
OPENVAS_REPORT_PATH=
NESSUS_REPORT_PATH=
ZAP_API_URL=
ZAP_API_KEY=
SCHEDULE_MAX_ENQUEUE_PER_CYCLE=20
SCHEDULE_QUEUE_MAX_DEPTH=250

# Alerting integrations
ALERT_WEBHOOK_URL=
ALERT_MIN_SEVERITY=HIGH
GITHUB_ISSUES_REPO=
JIRA_BASE_URL=
JIRA_EMAIL=
JIRA_API_TOKEN=
JIRA_PROJECT_KEY=
JIRA_ISSUE_TYPE=Task

# Optional graph backend
ENABLE_NEO4J=false
NEO4J_URI=
NEO4J_USER=
NEO4J_PASSWORD=

# Worker scaling and reliability
WORKER_ID=
WORKER_HEARTBEAT_TTL_SECONDS=45
SCAN_LOCK_TTL_SECONDS=3600
WORKER_MAX_ATTEMPTS=3

# Remediation ticketing (Jira Cloud). Without all four keys, tickets are tracked
# locally and reported as "not synced" — never fabricated as synced.
# JIRA_BASE_URL / JIRA_EMAIL / JIRA_API_TOKEN / JIRA_PROJECT_KEY set above.

# Patch automation (Ansible). Without these, patch jobs report "not_configured"
# and no patch is applied — the runner never fakes a successful deployment.
EMET_PATCH_PLAYBOOK=
EMET_PATCH_INVENTORY=

# CSPM connectors report "connected" only when real provider credentials exist.
# AWS: AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY
# GCP: GOOGLE_APPLICATION_CREDENTIALS
# Azure: AZURE_CLIENT_ID / AZURE_CLIENT_SECRET / AZURE_TENANT_ID

# Startup resilience
STARTUP_DB_RETRIES=20
STARTUP_DB_RETRY_DELAY_SECONDS=1.0

# Security and observability
DATA_ENCRYPTION_KEY=change-this-data-key
AUDIT_SIGNING_KEY=change-this-audit-key
RATE_LIMIT_SCAN_PER_MINUTE=6

# Optional graph mode
ENABLE_NEO4J=false
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME=EMET
